<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    mc:Ignorable="d" x:Class="ProcurementSystem.Wpf.Views.AuditLogView"
             d:DesignHeight="619.353">

    <UserControl.Resources>
        <SolidColorBrush x:Key="DarkBackground" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="DarkSurface" Color="#FF2D2D30"/>
        <SolidColorBrush x:Key="DarkBorder" Color="#FF3F3F46"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF007ACC"/>
        <SolidColorBrush x:Key="AccentHover" Color="#FF1C97EA"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF16C60C"/>
        <SolidColorBrush x:Key="SuccessHover" Color="#FF13A10A"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FFE74856"/>
        <SolidColorBrush x:Key="DangerHover" Color="#FFC93841"/>
        <SolidColorBrush x:Key="TextPrimary" Color="white"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FFB0B0B0"/>
        <SolidColorBrush x:Key="TextT" Color="#FF252526"/>
        <SolidColorBrush x:Key="GridHeaderBackground" Color="#FF252526"/>
        <SolidColorBrush x:Key="GridRowBackground" Color="#FF2D2D30"/>
        <SolidColorBrush x:Key="GridRowAlternate" Color="#FF333337"/>
        <SolidColorBrush x:Key="GridRowHover" Color="#FF3E3E42"/>
        <SolidColorBrush x:Key="InputBackground" Color="#FF3F3F46"/>
        <SolidColorBrush x:Key="InputBorder" Color="#FF5A5A5F"/>

        <Style x:Key="ModernButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="contentPresenter"
                                            Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Focusable="False"
                                            RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SuccessHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF0F9B08"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="contentPresenter"
                                            Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Focusable="False"
                                            RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DangerHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFB02A30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextT}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="{x:Type DatePicker}">
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextT}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextT}"/>
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{StaticResource GridRowBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{StaticResource GridRowBackground}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource GridRowAlternate}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{StaticResource GridHeaderBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource GridRowHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource DarkSurface}">
        <Border Background="{StaticResource DarkSurface}"
                BorderBrush="{StaticResource DarkBorder}"
                BorderThickness="0"
                CornerRadius="6"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" 
                        Background="{StaticResource DarkBackground}"
                        BorderBrush="{StaticResource DarkBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🔍 ФІЛЬТР ЛОГІВ" 
                                   FontWeight="SemiBold" 
                                   FontSize="14"
                                   Margin="0,0,0,12"
                                   Foreground="White"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" 
                                   Content="👤 Користувач:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" 
                                      x:Name="UserFilterCombo"
                                      DisplayMemberPath="FullName" 
                                      SelectedValuePath="Id"
                                      SelectionChanged="UserFilterCombo_SelectionChanged"
                                      Margin="0,0,16,0"/>

                            <Label Grid.Column="2" 
                                   Content="📅 З:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                            <DatePicker Grid.Column="3" 
                                        x:Name="DateFromPicker"
                                        SelectedDateChanged="DateFromPicker_SelectedDateChanged"
                                        Margin="0,0,16,0"/>

                            <Label Grid.Column="4" 
                                   Content="ПО:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                            <DatePicker Grid.Column="5" 
                                        x:Name="DateToPicker"
                                        SelectedDateChanged="DateToPicker_SelectedDateChanged"
                                        Margin="0,0,16,0"/>

                            <Button Grid.Column="7" 
                                    Content="🗑️ Очистити" 
                                    Click="ClearFilterButton_Click"
                                    Style="{StaticResource DangerButton}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Margin="0,0,0,12">
                    <Button x:Name="RefreshButton" 
                            Content="🔄 Оновити" 
                            Click="RefreshButton_Click"
                            Style="{StaticResource ModernButton}"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Background="{StaticResource GridRowBackground}"
                        BorderBrush="{StaticResource DarkBorder}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <DataGrid x:Name="AuditGrid"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" 
                                              Binding="{Binding ActionDate, StringFormat=dd.MM.yy HH:mm:ss}" 
                                              Width="160"/>
                            <DataGridTextColumn Header="Користувач" 
                                              Binding="{Binding User.FullName}" 
                                              Width="200"/>
                            <DataGridTextColumn Header="Дія" 
                                              Binding="{Binding Action}" 
                                              Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>