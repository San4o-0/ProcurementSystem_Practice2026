<Window x:Class="ProcurementSystem.Wpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Width="400"
        Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#1E1E1E">

    <Window.Resources>
        <ResourceDictionary>
            <!-- Colors -->
            <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D30"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#0E7490"/>
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#0891B2"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E4E4E7"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A1A1AA"/>
            <SolidColorBrush x:Key="InputBrush" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="InputFocusBrush" Color="#252526"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
            <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#FF4444"/>
            <SolidColorBrush x:Key="ErrorTextBrush" Color="White"/>

            <!-- Button Style -->
            <Style x:Key="ModernButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="20,12"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Label Style -->
            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Margin="20">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo -->
            <Border Grid.Row="0"
                    Width="56"
                    Height="56"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="12"
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center">
                <Viewbox Width="32" Height="32">
                    <Canvas Width="24" Height="24">
                        <Path Data="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z" 
                              Fill="White"/>
                    </Canvas>
                </Viewbox>
            </Border>

            <!-- Title -->
            <TextBlock Text="Procurement System"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"
                       Grid.Row="1"/>

            <TextBlock Text="Sign in to continue"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,28"
                       Grid.Row="2"/>

            <!-- Username Field -->
            <StackPanel Grid.Row="3" Margin="0,0,0,10">
                <TextBlock Text="Логін"
                           Style="{StaticResource LabelStyle}"/>
                <Border Background="{StaticResource InputBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Height="40">
                    <TextBox x:Name="LoginBox"
                             Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderThickness="0"
                             Padding="14,0"
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             CaretBrush="{StaticResource AccentBrush}"/>
                </Border>
            </StackPanel>

            <!-- Password Field -->
            <StackPanel Grid.Row="4" Margin="0,0,0,10">
                <!-- ✅ Зменшив Margin -->
                <TextBlock Text="Пароль" Style="{StaticResource LabelStyle}"/>
                <Border Background="{StaticResource InputBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Height="40">
                    <PasswordBox x:Name="PasswordBox"
                     Background="Transparent"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderThickness="0"
                     Padding="4,0"
                     VerticalContentAlignment="Center"
                     FontSize="14"
                     CaretBrush="{StaticResource AccentBrush}"/>
                </Border>
            </StackPanel>
            <!-- ✅ ErrorText ПІСЛЯ кнопки (Grid.Row="6") + Margin зверху -->
                            <TextBlock x:Name="ErrorText"
                Foreground="#FF6B6B" 
                Background="Transparent"
                FontSize="14"
                FontWeight="SemiBold"
                Margin="0,1,0,0"     
                Grid.Row="5"
                TextWrapping="Wrap"
                HorizontalAlignment="Center"
                Text=""
                Visibility="Visible"/>
            <!-- ✅ Login Button (Grid.Row="5") -->
            <Button Content="Увійти"
        Height="42"
        Grid.Row="6"
        Style="{StaticResource ModernButtonStyle}"
        Click="Login_Click"/>



        </Grid>
    </Border>
</Window>