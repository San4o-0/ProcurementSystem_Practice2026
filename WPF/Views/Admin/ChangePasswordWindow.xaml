<Window x:Class="ProcurementSystem.Wpf.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password"
        Width="420"
        Height="494"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Window.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D30"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#0E7490"/>
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#0891B2"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E4E4E7"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A1A1AA"/>
            <SolidColorBrush x:Key="InputBrush" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="CancelBrush" Color="#3F3F46"/>
            <SolidColorBrush x:Key="CancelHoverBrush" Color="#52525B"/>

            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <Style x:Key="InputBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource InputBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Height" Value="40"/>
            </Style>

            <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="14,0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource CancelBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource CancelHoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Margin="20">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Width="56"
                    Height="56"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="12"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Center">
                <Viewbox Width="32" Height="32">
                    <Canvas Width="24" Height="24">
                        <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" 
                              Fill="White"/>
                    </Canvas>
                </Viewbox>
            </Border>

            <TextBlock Text="Змінити пароль"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"
                       Grid.Row="1"/>

            <TextBlock Text="Введіть свій новий пароль"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"
                       Grid.Row="2"/>

            <StackPanel Grid.Row="3" Margin="0,0,0,16">
                <TextBlock Text="Новий пароль" Style="{StaticResource LabelStyle}"/>
                <Border Style="{StaticResource InputBorderStyle}">
                    <PasswordBox x:Name="PasswordBox1" Style="{StaticResource InputPasswordBoxStyle}"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,16">
                <TextBlock Text="Підтвердження паролю" Style="{StaticResource LabelStyle}"/>
                <Border Style="{StaticResource InputBorderStyle}">
                    <PasswordBox x:Name="PasswordBox2" Style="{StaticResource InputPasswordBoxStyle}"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="6"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0">
                <Button Content="Зберегти"
                        Width="100"
                        Margin="0,0,10,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Save_Click"/>
                <Button Content="Назад"
                        Width="100"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>