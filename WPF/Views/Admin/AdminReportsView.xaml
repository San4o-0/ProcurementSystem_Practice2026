<UserControl x:Class="ProcurementSystem.Wpf.Views.AdminReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">

    <UserControl.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D30"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#0E7490"/>
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#0891B2"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E4E4E7"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A1A1AA"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
            <SolidColorBrush x:Key="SuccessHoverBrush" Color="#059669"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
            <SolidColorBrush x:Key="WarningHoverBrush" Color="#F97316"/>
            <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
            <SolidColorBrush x:Key="DangerHoverBrush" Color="#DC2626"/>
            <SolidColorBrush x:Key="GridHeaderBrush" Color="#3F3F46"/>
            <SolidColorBrush x:Key="GridRowBrush" Color="#2D2D30"/>
            <SolidColorBrush x:Key="GridRowAlternateBrush" Color="#27272A"/>
            <SolidColorBrush x:Key="GridRowHoverBrush" Color="#3F3F46"/>
            <SolidColorBrush x:Key="GridRowSelectedBrush" Color="#0E7490"/>

            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SuccessButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource SuccessHoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WarningButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource WarningHoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DangerButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="DatePicker">
                <Setter Property="Background" Value="#1A1A1A"/>
                <Setter Property="Foreground" Value="#1A1A1A"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Height" Value="36"/>
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="RowBackground" Value="{StaticResource GridRowBrush}"/>
                <Setter Property="AlternatingRowBackground" Value="{StaticResource GridRowAlternateBrush}"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="SelectionUnit" Value="FullRow"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="RowHeight" Value="40"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource GridHeaderBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource GridRowHoverBrush}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource GridRowSelectedBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📊 Звіти та резервне копіювання"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Grid.Row="0"/>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Дата ВІД:"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,10,0"/>
                <DatePicker x:Name="DateFromPicker"
                            Width="150"
                            Margin="0,0,24,0"
                            SelectedDate="{x:Null}"
                            DisplayDateStart="{x:Null}"/>
                <TextBlock Text="ДО:"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,10,0"/>
                <DatePicker x:Name="DateToPicker"
                            Width="150"
                            Margin="0,0,24,0"
                            SelectedDate="{x:Null}"
                            DisplayDateStart="{x:Null}"/>
                <Button x:Name="ClearDatesBtn"
                        Content="🗑️ Очистити"
                        Click="ClearDatesBtn_Click"
                        Style="{StaticResource DangerButtonStyle}"/>
            </StackPanel>
        </Border>


<!-- Grid.Row="4" - ЗАМІНИ на це: -->
<Grid Grid.Row="4">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="16"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    
    <!-- ✅ РЯД 1 -->
    <WrapPanel Grid.Row="0" Orientation="Horizontal">
        <Button x:Name="RequestsReportBtn" Content="📈 Звіт по заявках" 
                Click="RequestsReportBtn_Click" Style="{StaticResource PrimaryButtonStyle}" 
                Margin="0,0,8,0" MinWidth="160"/>
        <Button x:Name="OrdersReportBtn" Content="📋 Звіт по замовленнях" 
                Click="OrdersReportBtn_Click" Style="{StaticResource PrimaryButtonStyle}" 
                Margin="0,0,8,0" MinWidth="160"/>
        <Button x:Name="Top10Btn" Content="🏆 Топ-10 найдорожчих" 
                Click="Top10Btn_Click" Style="{StaticResource PrimaryButtonStyle}" 
                Margin="0,0,8,0" MinWidth="160"/>
        <Button x:Name="UserReportBtn" Content="👥 По користувачах" 
                Click="UserReportBtn_Click" Style="{StaticResource PrimaryButtonStyle}" 
                Margin="0,0,8,0" MinWidth="160"/>
    </WrapPanel>
    
    <!-- ✅ РЯД 2 -->
    <WrapPanel Grid.Row="2" Orientation="Horizontal">
        <Button x:Name="StatusReportBtn" Content="📊 По статусах" 
                Click="StatusReportBtn_Click" Style="{StaticResource PrimaryButtonStyle}" 
                Margin="0,0,8,0" MinWidth="140"/>
        <Button x:Name="ExcelExportBtn" Content="📊 Excel Export" 
                Click="ExcelExportBtn_Click" Style="{StaticResource WarningButtonStyle}" 
                Margin="0,0,8,0" MinWidth="140"/>
        <Button x:Name="BackupBtn" Content="💾 Резервна копія" 
                Click="BackupBtn_Click" Style="{StaticResource SuccessButtonStyle}" 
                Margin="0,0,8,0" MinWidth="160"/>
                <Button x:Name="RestoreBtn" Content="🔄 Відновити БД" 
        Click="RestoreBtn_Click" Style="{StaticResource DangerButtonStyle}" 
        Margin="0,0,8,0" MinWidth="140" ToolTip="Відновити з .bak файлу"/>
                <ComboBox x:Name="ImportModeCombo" Width="150" Margin="5" SelectedIndex="0">
                    <ComboBoxItem Content="Додати нові (безпечний)"/>
                    <ComboBoxItem Content="Повне оновлення"/>
                </ComboBox>

            </WrapPanel>
</Grid>

        <Border Grid.Row="6"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <DataGrid x:Name="ReportsGrid"
                      IsReadOnly="True"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="110"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="150"/>
                    <DataGridTextColumn Header="Користувач" Binding="{Binding User}" Width="200"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="130"/>
                    <DataGridTextColumn Header="Коментар" Binding="{Binding Comment}" Width="*"/>
                    <DataGridTextColumn Header="Сума" Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock x:Name="StatusText"
                   Grid.Row="8"
                   Foreground="{StaticResource SuccessBrush}"
                   FontWeight="SemiBold"
                   FontSize="14"/>
    </Grid>
</UserControl>